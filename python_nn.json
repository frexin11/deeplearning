	"PyTorch CNN Boilerplate": {
		"prefix": "mantra25",
		"body": [
			"# ============================================",
			"# CNN IMPLEMENTATION IN PYTORCH",
			"# ============================================",
			"",
			"import torch",
			"import torch.nn as nn",
			"import torch.optim as optim",
			"from torch.utils.data import TensorDataset, DataLoader",
			"",
			"# ============================================",
			"# STEP 1 : GENERATE SYNTHETIC DATASET",
			"# ============================================",
			"",
			"# 6000 grayscale images of size 32x32",
			"X = torch.rand(6000, 1, 32, 32)   # normalized in [0,1]",
			"",
			"# labels for 6 classes",
			"labels = torch.randint(0, 6, (6000,))",
			"",
			"# one-hot encoding",
			"Y = torch.zeros(6000, 6)",
			"Y[torch.arange(6000), labels] = 1",
			"",
			"# batch size",
			"B = 64",
			"",
			"dataset = TensorDataset(X, labels)",
			"loader = DataLoader(dataset, batch_size=B, shuffle=True)",
			"",
			"# ============================================",
			"# STEP 2 : DEFINE CNN ARCHITECTURE",
			"# ============================================",
			"",
			"class CNN(nn.Module):",
			"",
			"\tdef __init__(self):",
			"\t\tsuper(CNN, self).__init__()",
			"",
			"\t\t# Layer 1",
			"\t\t# 16 filters, kernel=3x3, stride=1, padding=1",
			"\t\tself.conv1 = nn.Conv2d(",
			"\t\t\tin_channels=1,",
			"\t\t\tout_channels=16,",
			"\t\t\tkernel_size=3,",
			"\t\t\tstride=1,",
			"\t\t\tpadding=1",
			"\t\t)",
			"",
			"\t\tself.relu1 = nn.ReLU()",
			"",
			"\t\tself.pool1 = nn.MaxPool2d(",
			"\t\t\tkernel_size=2,",
			"\t\t\tstride=2",
			"\t\t)",
			"",
			"\t\t# Layer 2",
			"\t\t# 32 filters, kernel=3x3, stride=1, padding=1",
			"\t\tself.conv2 = nn.Conv2d(",
			"\t\t\tin_channels=16,",
			"\t\t\tout_channels=32,",
			"\t\t\tkernel_size=3,",
			"\t\t\tstride=1,",
			"\t\t\tpadding=1",
			"\t\t)",
			"",
			"\t\tself.relu2 = nn.ReLU()",
			"",
			"\t\tself.pool2 = nn.MaxPool2d(",
			"\t\t\tkernel_size=2,",
			"\t\t\tstride=2",
			"\t\t)",
			"",
			"\t\t# Flatten size calculation:",
			"\t\t# Input = 32x32",
			"\t\t# After pool1 = 16x16",
			"\t\t# After pool2 = 8x8",
			"\t\t# Channels = 32",
			"\t\t# Flatten = 32*8*8 = 2048",
			"",
			"\t\tself.fc = nn.Linear(32 * 8 * 8, 6)",
			"",
			"\tdef forward(self, x):",
			"",
			"\t\t# -----------------------------",
			"\t\t# Conv Layer 1",
			"\t\t# -----------------------------",
			"\t\tz1 = self.conv1(x)",
			"\t\t# print(\"z1 shape =\", z1.shape)",
			"",
			"\t\ta1 = self.relu1(z1)",
			"\t\t# print(\"a1 shape =\", a1.shape)",
			"",
			"\t\tp1 = self.pool1(a1)",
			"\t\t# print(\"pool1 shape =\", p1.shape)",
			"",
			"\t\t# -----------------------------",
			"\t\t# Conv Layer 2",
			"\t\t# -----------------------------",
			"\t\tz2 = self.conv2(p1)",
			"\t\t# print(\"z2 shape =\", z2.shape)",
			"",
			"\t\ta2 = self.relu2(z2)",
			"\t\t# print(\"a2 shape =\", a2.shape)",
			"",
			"\t\tp2 = self.pool2(a2)",
			"\t\t# print(\"pool2 shape =\", p2.shape)",
			"",
			"\t\t# -----------------------------",
			"\t\t# Flatten",
			"\t\t# -----------------------------",
			"\t\tflat = p2.view(p2.size(0), -1)",
			"\t\t# print(\"flatten shape =\", flat.shape)",
			"",
			"\t\t# -----------------------------",
			"\t\t# Fully Connected",
			"\t\t# -----------------------------",
			"\t\tz3 = self.fc(flat)",
			"\t\t# print(\"output shape =\", z3.shape)",
			"",
			"\t\treturn z3",
			"",
			"",
			"# ============================================",
			"# STEP 3 : CREATE MODEL",
			"# ============================================",
			"",
			"model = CNN()",
			"",
			"# ============================================",
			"# STEP 4 : LOSS FUNCTION + OPTIMIZER",
			"# ============================================",
			"",
			"criterion = nn.CrossEntropyLoss()",
			"",
			"optimizer = optim.SGD(",
			"\tmodel.parameters(),",
			"\tlr=0.01",
			")",
			"",
			"# ============================================",
			"# STEP 5 : TRAINING",
			"# ============================================",
			"",
			"epochs = 10",
			"",
			"for epoch in range(epochs):",
			"",
			"\ttotal_loss = 0",
			"",
			"\tfor images, targets in loader:",
			"",
			"\t\t# forward pass",
			"\t\toutputs = model(images)",
			"",
			"\t\t# compute loss",
			"\t\tloss = criterion(outputs, targets)",
			"",
			"\t\t# backward pass",
			"\t\toptimizer.zero_grad()",
			"\t\tloss.backward()",
			"",
			"\t\t# update weights",
			"\t\toptimizer.step()",
			"",
			"\t\ttotal_loss += loss.item()",
			"",
			"\tavg_loss = total_loss / len(loader)",
			"",
			"\tprint(f\"\\nEpoch [{epoch+1}/{epochs}] Loss = {avg_loss:.4f}\")",
			"",
			"# ============================================",
			"# STEP 6 : PARAMETER SHAPES",
			"# ============================================",
			"",
			"print(\"\\nParameter Shapes:\\n\")",
			"",
			"print(\"W1 =\", model.conv1.weight.shape)",
			"print(\"b1 =\", model.conv1.bias.shape)",
			"",
			"print(\"W2 =\", model.conv2.weight.shape)",
			"print(\"b2 =\", model.conv2.bias.shape)",
			"",
			"print(\"W3 =\", model.fc.weight.shape)",
			"print(\"b3 =\", model.fc.bias.shape)",
			"",
			"# ============================================",
			"# OUTPUT SHAPES",
			"# ============================================",
			"",
			"\"\"\"",
			"Input Shape:",
			"(B,1,32,32)",
			"",
			"After Conv1:",
			"(B,16,32,32)",
			"",
			"After Pool1:",
			"(B,16,16,16)",
			"",
			"After Conv2:",
			"(B,32,16,16)",
			"",
			"After Pool2:",
			"(B,32,8,8)",
			"",
			"Flatten:",
			"(B,2048)",
			"",
			"Final Output:",
			"(B,6)",
			"\"\"\""
		],
		"description": "PyTorch CNN Full Boilerplate"
	}

