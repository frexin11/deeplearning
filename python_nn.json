{
	"PyTorch MNIST Boilerplate": {
		"prefix": "mantra",
		"body": [
			"# ============================================",
			"# STEP 1 : DATA PREPARATION",
			"# ============================================",
			"",
			"import torch",
			"import torchvision",
			"import torchvision.transforms as transforms",
			"from torch.utils.data import DataLoader",
			"",
			"# Transform:",
			"# Convert image to tensor and normalize pixel values to [0,1]",
			"",
			"transform = transforms.ToTensor()",
			"",
			"# Load MNIST dataset",
			"train_dataset = torchvision.datasets.MNIST(",
			"\troot='./data',",
			"\ttrain=True,",
			"\tdownload=True,",
			"\ttransform=transform",
			")",
			"",
			"test_dataset = torchvision.datasets.MNIST(",
			"\troot='./data',",
			"\ttrain=False,",
			"\tdownload=True,",
			"\ttransform=transform",
			")",
			"",
			"# Data Loader",
			"train_loader = DataLoader(",
			"\tdataset=train_dataset,",
			"\tbatch_size=32,",
			"\tshuffle=True",
			")",
			"",
			"test_loader = DataLoader(",
			"\tdataset=test_dataset,",
			"\tbatch_size=32,",
			"\tshuffle=False",
			")",
			"",
			"print(\"Training Samples :\", len(train_dataset))",
			"print(\"Testing Samples  :\", len(test_dataset))",
			"",
			"",
			"# ============================================",
			"# STEP 2 : NETWORK ARCHITECTURE",
			"# ============================================",
			"",
			"import torch.nn as nn",
			"",
			"class NeuralNetwork(nn.Module):",
			"",
			"\tdef __init__(self):",
			"\t\tsuper(NeuralNetwork, self).__init__()",
			"",
			"\t\tself.model = nn.Sequential(",
			"",
			"\t\t\t# Input Layer = 784",
			"\t\t\tnn.Flatten(),",
			"",
			"\t\t\t# Hidden Layer 1",
			"\t\t\tnn.Linear(28*28, 128),",
			"\t\t\tnn.ReLU(),",
			"",
			"\t\t\t# Hidden Layer 2",
			"\t\t\tnn.Linear(128, 64),",
			"\t\t\tnn.ReLU(),",
			"",
			"\t\t\t# Output Layer",
			"\t\t\tnn.Linear(64, 10),",
			"\t\t\tnn.Softmax(dim=1)",
			"\t\t)",
			"",
			"\tdef forward(self, x):",
			"\t\treturn self.model(x)",
			"",
			"# Create Model",
			"model = NeuralNetwork()",
			"",
			"print(model)",
			"",
			"",
			"# ============================================",
			"# STEP 3 : TRAINING THE NETWORK",
			"# ============================================",
			"",
			"import torch.optim as optim",
			"",
			"# Loss Function",
			"criterion = nn.CrossEntropyLoss()",
			"",
			"# Optimizer",
			"optimizer = optim.Adam(model.parameters(), lr=0.001)",
			"",
			"# Training",
			"epochs = 10",
			"",
			"for epoch in range(epochs):",
			"",
			"\trunning_loss = 0.0",
			"",
			"\tfor images, labels in train_loader:",
			"",
			"\t\t# Forward Pass",
			"\t\toutputs = model(images)",
			"",
			"\t\t# Calculate Loss",
			"\t\tloss = criterion(outputs, labels)",
			"",
			"\t\t# Backpropagation",
			"\t\toptimizer.zero_grad()",
			"\t\tloss.backward()",
			"\t\toptimizer.step()",
			"",
			"\t\trunning_loss += loss.item()",
			"",
			"\tprint(f\"Epoch [{epoch+1}/{epochs}] Loss: {running_loss/len(train_loader):.4f}\")",
			"",
			"print(\"Training Completed\")",
			"",
			"# ============================================",
			"# STEP 4 : EVALUATION",
			"# ============================================",
			"",
			"correct = 0",
			"total = 0",
			"test_loss = 0.0",
			"",
			"model.eval()",
			"",
			"with torch.no_grad():",
			"",
			"\tfor images, labels in test_loader:",
			"",
			"\t\toutputs = model(images)",
			"",
			"\t\t# Loss",
			"\t\tloss = criterion(outputs, labels)",
			"\t\ttest_loss += loss.item()",
			"",
			"\t\t# Prediction",
			"\t\t_, predicted = torch.max(outputs.data, 1)",
			"",
			"\t\ttotal += labels.size(0)",
			"\t\tcorrect += (predicted == labels).sum().item()",
			"",
			"# Accuracy",
			"accuracy = 100 * correct / total",
			"",
			"print(f\"Test Loss     : {test_loss/len(test_loader):.4f}\")",
			"print(f\"Test Accuracy : {accuracy:.2f}%\")",
			"",
			"",
			"# ============================================",
			"# STEP 5 : HYPERPARAMETER TUNING",
			"# ============================================",
			"",
			"learning_rates = [0.01, 0.001, 0.0001]",
			"batch_sizes = [32, 64, 128]",
			"",
			"results = []",
			"",
			"for lr in learning_rates:",
			"",
			"\tfor batch_size in batch_sizes:",
			"",
			"\t\tprint(f\"\\nTraining with LR={lr} and Batch Size={batch_size}\")",
			"",
			"\t\t# DataLoader",
			"\t\ttrain_loader = DataLoader(",
			"\t\t\tdataset=train_dataset,",
			"\t\t\tbatch_size=batch_size,",
			"\t\t\tshuffle=True",
			"\t\t)",
			"",
			"\t\ttest_loader = DataLoader(",
			"\t\t\tdataset=test_dataset,",
			"\t\t\tbatch_size=batch_size,",
			"\t\t\tshuffle=False",
			"\t\t)",
			"",
			"\t\t# Model",
			"\t\tmodel = NeuralNetwork()",
			"",
			"\t\t# Loss and Optimizer",
			"\t\tcriterion = nn.CrossEntropyLoss()",
			"\t\toptimizer = optim.Adam(model.parameters(), lr=lr)",
			"",
			"\t\t# Train Model",
			"\t\tepochs = 5",
			"",
			"\t\tfor epoch in range(epochs):",
			"",
			"\t\t\tfor images, labels in train_loader:",
			"",
			"\t\t\t\toutputs = model(images)",
			"",
			"\t\t\t\tloss = criterion(outputs, labels)",
			"",
			"\t\t\t\toptimizer.zero_grad()",
			"\t\t\t\tloss.backward()",
			"\t\t\t\toptimizer.step()",
			"",
			"\t\t# Evaluation",
			"\t\tcorrect = 0",
			"\t\ttotal = 0",
			"",
			"\t\tmodel.eval()",
			"",
			"\t\twith torch.no_grad():",
			"",
			"\t\t\tfor images, labels in test_loader:",
			"",
			"\t\t\t\toutputs = model(images)",
			"",
			"\t\t\t\t_, predicted = torch.max(outputs.data, 1)",
			"",
			"\t\t\t\ttotal += labels.size(0)",
			"\t\t\t\tcorrect += (predicted == labels).sum().item()",
			"",
			"\t\taccuracy = 100 * correct / total",
			"",
			"\t\tprint(f\"Accuracy = {accuracy:.2f}%\")",
			"",
			"\t\tresults.append((lr, batch_size, accuracy))",
			"",
			"# Final Results",
			"print(\"\\n========== FINAL RESULTS ==========\")",
			"",
			"for lr, batch_size, accuracy in results:",
			"\tprint(f\"LR={lr}, Batch Size={batch_size} --> Accuracy={accuracy:.2f}%\")",
			"",
			"",
			"# ============================================",
			"# STEP 6 : VISUALIZATION",
			"# ============================================",
			"",
			"import matplotlib.pyplot as plt",
			"",
			"# Lists to store loss and accuracy",
			"train_losses = []",
			"train_accuracies = []",
			"",
			"epochs = 10",
			"",
			"# Recreate model",
			"model = NeuralNetwork()",
			"",
			"criterion = nn.CrossEntropyLoss()",
			"optimizer = optim.Adam(model.parameters(), lr=0.001)",
			"",
			"# ================= TRAINING =================",
			"",
			"for epoch in range(epochs):",
			"",
			"\trunning_loss = 0.0",
			"\tcorrect = 0",
			"\ttotal = 0",
			"",
			"\tmodel.train()",
			"",
			"\tfor images, labels in train_loader:",
			"",
			"\t\t# Forward Pass",
			"\t\toutputs = model(images)",
			"",
			"\t\t# Loss",
			"\t\tloss = criterion(outputs, labels)",
			"",
			"\t\t# Backpropagation",
			"\t\toptimizer.zero_grad()",
			"\t\tloss.backward()",
			"\t\toptimizer.step()",
			"",
			"\t\trunning_loss += loss.item()",
			"",
			"\t\t# Accuracy",
			"\t\t_, predicted = torch.max(outputs.data, 1)",
			"",
			"\t\ttotal += labels.size(0)",
			"\t\tcorrect += (predicted == labels).sum().item()",
			"",
			"\tepoch_loss = running_loss / len(train_loader)",
			"\tepoch_accuracy = 100 * correct / total",
			"",
			"\ttrain_losses.append(epoch_loss)",
			"\ttrain_accuracies.append(epoch_accuracy)",
			"",
			"\tprint(f\"Epoch [{epoch+1}/{epochs}] \"",
			"\t\t  f\"Loss: {epoch_loss:.4f} \"",
			"\t\t  f\"Accuracy: {epoch_accuracy:.2f}%\")",
			"",
			"# ============================================",
			"# PLOT LOSS GRAPH",
			"# ============================================",
			"",
			"plt.figure(figsize=(8,5))",
			"",
			"plt.plot(range(1, epochs+1), train_losses, marker='o')",
			"",
			"plt.title(\"Training Loss over Epochs\")",
			"plt.xlabel(\"Epochs\")",
			"plt.ylabel(\"Loss\")",
			"",
			"plt.grid(True)",
			"plt.show()",
			"",
			"# ============================================",
			"# PLOT ACCURACY GRAPH",
			"# ============================================",
			"",
			"plt.figure(figsize=(8,5))",
			"",
			"plt.plot(range(1, epochs+1), train_accuracies, marker='o')",
			"",
			"plt.title(\"Training Accuracy over Epochs\")",
			"plt.xlabel(\"Epochs\")",
			"plt.ylabel(\"Accuracy\")",
			"",
			"plt.grid(True)",
			"plt.show()",
			"",
			"# ============================================",
			"# VISUALIZE TEST IMAGES",
			"# ============================================",
			"",
			"model.eval()",
			"",
			"examples = iter(test_loader)",
			"images, labels = next(examples)",
			"",
			"outputs = model(images)",
			"",
			"_, predicted = torch.max(outputs, 1)",
			"",
			"# Show first 5 images",
			"plt.figure(figsize=(12,4))",
			"",
			"for i in range(5):",
			"",
			"\tplt.subplot(1,5,i+1)",
			"",
			"\tplt.imshow(images[i][0], cmap='gray')",
			"",
			"\tplt.title(f\"P:{predicted[i].item()} T:{labels[i].item()}\")",
			"",
			"\tplt.axis('off')",
			"",
			"plt.show()"
		],
		"description": "PyTorch MNIST Full Boilerplate"
	}
}
